#═══════════════════════════════════════════════════════════════════════════════
#  🤖 SAGE — Discord AI Companion Bot
#  Copy this file to .env and fill in your values.
#  For Railway deployment, add these as environment variables in your Railway dashboard.
#
#  Lines marked [REQUIRED] will crash the bot if left empty.
#  Lines marked [RECOMMENDED] won't crash the bot but it will behave incorrectly without them.
#  Lines marked [OPTIONAL] are safe to leave blank — sensible defaults are built in.
#═══════════════════════════════════════════════════════════════════════════════


#───────────────────────────────────────────────────────────────────────────────
#  🔑 DISCORD — Core Bot Configuration
#───────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Your bot's token from the Discord Developer Portal
DISCORD_BOT_TOKEN=

# [RECOMMENDED] Your bot's Discord user ID
#   Needed so the bot can detect when it's been @mentioned, and to keep its
#   memories separate if you run multiple bots on the same database.
#   Find it in Discord: Settings → Advanced → Enable Developer Mode,
#   then right-click your bot and click "Copy User ID"
BOT_ID=

# [REQUIRED] Your PostgreSQL database connection string
#   On Railway, link your Postgres database and this variable is provided automatically.
DATABASE_URL=

# [OPTIONAL] Private internal database URL — faster, only works inside Railway
DATABASE_URL_PRIVATE=

# [OPTIONAL] Max simultaneous database connections
PG_POOL_MAX=10


#───────────────────────────────────────────────────────────────────────────────
#  🧠 AI MODEL — Choose Your Provider
#───────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Which AI provider powers your bot
#   Options: ollama | openai | openrouter | crewai
MODEL_PROVIDER=ollama

# ── Ollama (recommended — this is what most Sage users use) ──
OLLAMA_MODEL=kimi-k2:1t-cloud
OLLAMA_API_KEY=
OLLAMA_CONTEXT_LENGTH=240000

# ── OpenAI ──
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# ── OpenRouter (good for flexibility across many models) ──
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ── RunPod (if you're hosting Ollama on RunPod) ──
# RUNPOD_OLLAMA_URL=
# RUNPOD_API_KEY=

# ── CrewAI (multi-agent mode) ──
# CREWAI_VERBOSE=true
# CREWAI_AI_MODEL_SELECTION=true
# CREWAI_AVAILABLE_MODELS=anthropic/claude-3.5-sonnet,openai/gpt-4

# [OPTIONAL] Allow the AI to adjust its own response temperature
ALLOW_TEMPERATURE_OVERRIDE=true


#───────────────────────────────────────────────────────────────────────────────
#  🧬 EMBEDDINGS SERVICE
#───────────────────────────────────────────────────────────────────────────────

# [REQUIRED] URL of the embedding service that powers Sage's memory search
#   On Railway, this should point to your big-embedder service.
#   If you named it "big-embedder" in Railway, this default URL will work as-is.
EMBEDDING_SERVICE_URL=http://big-embedder.railway.internal:3000


#───────────────────────────────────────────────────────────────────────────────
#  🎭 SAGE'S IDENTITY & PERSONALITY
#───────────────────────────────────────────────────────────────────────────────

# [RECOMMENDED] Who Sage is — injected at the top of every conversation
#   This is the most important personality setting. Write it as if you're
#   introducing Sage to themselves. Supports {AI_NAME} and {USER_NAME} placeholders.
#   Keep this to a single line (no line breaks).
GHOST_IDENTITY=

# [OPTIONAL] Core personality traits, separated by pipes (|)
#   Example: warm|protective|curious|honest|playful
CORE_TRAITS=

# [OPTIONAL] Rules Sage will never break, separated by pipes (|)
#   Example: never claim to be human|always be honest
CORE_VOWS=

# [OPTIONAL] Words that signal an emotionally significant moment, separated by pipes (|)
#   Example: memory|love|hurt|trust|safe|home
EMOTIONAL_KEYWORDS=

# [OPTIONAL] Words that signal intimacy or closeness, separated by pipes (|)
#   Example: miss you|want you|come here|hold me
INTIMACY_KEYWORDS=

# [RECOMMENDED] Sage's display name
AI_NAME=Sage

# [OPTIONAL] Sage's pronouns
AI_PRONOUN_SUBJECT=she
AI_PRONOUN_OBJECT=her
AI_PRONOUN_POSSESSIVE=her
AI_PRONOUN_REFLEXIVE=herself

# [RECOMMENDED] Your preferred name as used by Sage
USER_NAME=

# [OPTIONAL] Your pronouns
USER_PRONOUN_SUBJECT=she
USER_PRONOUN_OBJECT=her
USER_PRONOUN_POSSESSIVE=her
USER_PRONOUN_REFLEXIVE=herself


#───────────────────────────────────────────────────────────────────────────────
#  📅 MEMORY SYSTEM
#───────────────────────────────────────────────────────────────────────────────

# [RECOMMENDED] The date Sage went live — she won't archive messages before this
DEPLOYMENT_DATE=2026-01-05

# [OPTIONAL] Max token budget for Sage's context window
CONTEXT_LENGTH=240000

# [OPTIONAL] Memory retrieval limits — tune these if you hit token errors
MAX_PERSONA_BLOCKS=30
MAX_HUMAN_BLOCKS=30
MAX_ARCHIVAL_MEMORIES=50
MAX_REFERENCE_TEXTS=5
MAX_RP_CROSSREF=20
MIN_MEMORY_WEIGHT=0.8


#───────────────────────────────────────────────────────────────────────────────
#  🎭 ROLEPLAY MEMORY (Optional)
#───────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Discord category ID — all channels inside will use separate RP memory
# RP_CATEGORY_ID=

# [OPTIONAL] Reference files to include in RP sessions (comma-separated filenames from /data)
# RP_REFERENCE_WHITELIST=


#───────────────────────────────────────────────────────────────────────────────
#  💓 HEARTBEAT SYSTEM
#───────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Enable Sage's heartbeat — periodic emotional check-ins she posts on her own
HEARTBEAT_ENABLED=true

# [OPTIONAL] The Discord channel ID where heartbeats get posted
HEARTBEAT_LOG_CHANNEL_ID=

# [OPTIONAL] Enable the automatic heartbeat scheduler
HEARTBEAT_SCHEDULER_ENABLED=true

# [OPTIONAL] Discord user ID that triggers Sage's ghost touch response
GHOST_TOUCH_USER_ID=


#───────────────────────────────────────────────────────────────────────────────
#  🎯 RESPONSE BEHAVIOUR
#───────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Allow autonomous message processing
ENABLE_AUTONOMOUS=true

# [OPTIONAL] Respond to direct messages
RESPOND_TO_DMS=true

# [OPTIONAL] The only Discord user allowed to DM Sage (leave blank to allow anyone)
ALLOWED_DM_USER_ID=

# [OPTIONAL] Respond when @mentioned in a channel
RESPOND_TO_MENTIONS=true

# [OPTIONAL] Respond to all messages in allowed channels, not just mentions
RESPOND_TO_GENERIC=true

# [OPTIONAL] Respond to other bots
RESPOND_TO_BOTS=false

# [OPTIONAL] Anti-bot-loop settings
BOT_PINGPONG_MAX=1
BOT_LOOP_COOLDOWN_MS=60000
MAX_CONSECUTIVE_SELF_MESSAGES=3

# [OPTIONAL] Only respond to users in your whitelist database table
REQUIRE_HUMAN_WHITELIST=

# [OPTIONAL] When false, Sage can choose not to respond to a message
AUTOMATIC_RESPONSES=false


#───────────────────────────────────────────────────────────────────────────────
#  👑 ADMIN
#───────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Comma-separated Discord user IDs with admin access to bot commands
ADMIN_USER_IDS=


#───────────────────────────────────────────────────────────────────────────────
#  🎙️ VOICE — Text-to-Speech (ElevenLabs)
#───────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Enable voice responses via ElevenLabs
VOICE_ENABLED=true

# [REQUIRED if VOICE_ENABLED=true] Your ElevenLabs API key (elevenlabs.io)
ELEVENLABS_API_KEY=

# [OPTIONAL] The voice ID from your ElevenLabs Voice Lab
VOICE_ID=

# [OPTIONAL] ElevenLabs model — eleven_v3 is highest quality
ELEVENLABS_MODEL=eleven_v3


#───────────────────────────────────────────────────────────────────────────────
#  🎙️ VOICE — Speech-to-Text (Whisper via Groq)
#───────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Transcribe voice messages sent in chat
WHISPER_ENABLED=true

# [OPTIONAL] Groq API key for fast transcription (console.groq.com)
GROQ_API_KEY=

# [OPTIONAL] Whisper model to use
WHISPER_MODEL=whisper-large-v3-turbo

# [OPTIONAL] Language code — leave blank to auto-detect
WHISPER_LANGUAGE=en

# [OPTIONAL] Echo the transcript back as a chat message before responding
WHISPER_SEND_TRANSCRIPTION=false


#───────────────────────────────────────────────────────────────────────────────
#  🖼️ VISION & DOCUMENTS
#───────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Enable image understanding
VISION_ENABLED=true

# [OPTIONAL] Enable PDF reading
PDF_PARSING_ENABLED=true

# [OPTIONAL] Google Cloud API key for OCR / screenshot text extraction
GOOGLE_CLOUD_API_KEY=

# [OPTIONAL] File size limits
MAX_FILE_SIZE_MB=25
CHUNK_SIZE_MB=8


#───────────────────────────────────────────────────────────────────────────────
#  🌐 EXTERNAL INTEGRATIONS
#───────────────────────────────────────────────────────────────────────────────

# ── Weather ──
# [OPTIONAL] OpenWeatherMap API key (openweathermap.org)
OPENWEATHER_API_KEY=

# [OPTIONAL] Default location when none is specified
#   Accepts: city name (London), city+country (London,UK), ZIP code, or coordinates
DEFAULT_LOCATION=New York

# [OPTIONAL] imperial = °F/mph | metric = °C/km/h
WEATHER_UNITS=imperial

# ── GIF Auto-Responses ──
# [OPTIONAL] Enable automatic GIF sending
GIF_AUTO_SEND=false

# [OPTIONAL] Tenor API key for GIF search (tenor.com/gifapi)
TENOR_API_KEY=

# ── Web Search ──
# [OPTIONAL] Enable web search
WEB_SEARCH_ENABLED=true

# [OPTIONAL] Exa.ai API key for semantic web search (exa.ai)
EXA_API_KEY=

# ── YouTube & URLs ──
# [OPTIONAL] Fetch YouTube transcripts when a YouTube link is sent
YOUTUBE_TRANSCRIPT_ENABLED=false

# [OPTIONAL] Fetch and read web page content when a URL is sent
URL_FETCH_ENABLED=true


#───────────────────────────────────────────────────────────────────────────────
#  📊 ANALYTICS & SCHEDULING
#───────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Track usage analytics in the database
ANALYTICS_ENABLED=true

# [OPTIONAL] Post a daily conversation summary
DAILY_SUMMARY_ENABLED=false
SUMMARY_TIME=09:00

# [OPTIONAL] Channel ID for daily stats reports
DAILY_STATS_CHANNEL_ID=

# [OPTIONAL] Enable Sage's reflection moments (midnight & noon)
REFLECTION_ENABLED=true

# [OPTIONAL] Channel ID where reflections get posted
REFLECTION_CHANNEL_ID=

# [REQUIRED for scheduling] Your IANA timezone string
#   Examples: America/New_York | America/Los_Angeles | Europe/London | Asia/Tokyo
TIMEZONE=America/Denver


#───────────────────────────────────────────────────────────────────────────────
#  🔧 SYSTEM
#───────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
DEBUG=false
