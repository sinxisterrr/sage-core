{
  "name": "Sage-Core",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc -p tsconfig.json && cp src/db/*.sql dist/db/ 2>/dev/null || true && cp -r src/db/migrations dist/db/ 2>/dev/null || true && mkdir -p dist/scripts",
    "migrate-embeddings": "node dist/scripts/embedMigrationFromJSON.js",
    "reset-db": "tsx scripts/reset-continuum-tables.ts",
    "clean-db": "tsx scripts/clean-database.ts",
    "check-db": "tsx check-vector-db.ts"
  },
  "dependencies": {
    "@google-cloud/vision": "^5.3.4",
    "axios": "^1.7.9",
    "discord.js": "^14.15.3",
    "dotenv": "^17.2.3",
    "elevenlabs": "^1.59.0",
    "form-data": "^4.0.0",
    "mammoth": "^1.8.0",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.3",
    "sharp": "^0.33.5",
    "tesseract.js": "^5.1.1",
    "tiktoken": "^1.0.22",
    "word-extractor": "^1.0.4",
    "youtube-transcript": "^1.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.26",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.16.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
